{
  "rewrites": [
    {
      "source": "/smsservice",
      "destination": "https://smsservice-v2.vercel.app/smsservice"
    },
    {
      "source": "/smsservice/:match*",
      "destination": "https://smsservice-v2.vercel.app/smsservice/:match*"
    },
    {
      "source": "/smsservice-gate",
      "destination": "https://smsservice-v2.vercel.app/smsservice-gate"
    },
    {
      "source": "/verify-gate",
      "destination": "https://smsservice-v2.vercel.app/verify-gate"
    },
    {
      "source": "/portal",
      "destination": "https://smsservice-v2.vercel.app/portal"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}